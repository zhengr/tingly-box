{
    "capability_schemas": {
        "web_search_anthropic": {
            "built_in": true,
            "tool_type": "web_search_20250305",
            "tool_name": "web_search",
            "doc_url": "https://platform.claude.com/docs/en/agents-and-tools/tool-use/web-search-tool",
            "result_format": {
                "type": "web_search_tool_result",
                "description": "Anthropic returns results as a web_search_tool_result content block in the message",
                "structure": {
                    "type": "web_search_tool_result",
                    "tool_use_id": "<id_from_server_tool_use>",
                    "content": [
                        {
                            "type": "web_search_result",
                            "url": "https://example.com",
                            "title": "Result Title",
                            "encrypted_content": "base64_encoded_content",
                            "page_age": "April 30, 2025"
                        }
                    ]
                }
            }
        },
        "web_search_glm": {
            "built_in": true,
            "tool_type": "web_search",
            "doc_url": "https://open.bigmodel.cn/dev/api/search-tool/websearch-in-chat",
            "result_format": {
                "type": "top_level_array",
                "description": "GLM returns results in a top-level 'web_search' array outside the choices",
                "structure": {
                    "web_search": [
                        {
                            "title": "Search Result Title",
                            "link": "https://example.com",
                            "content": "Full content text...",
                            "media": "Source Name",
                            "icon": "https://icon.url",
                            "publish_date": "2025-04-23",
                            "refer": "ref_1"
                        }
                    ]
                },
                "field": "web_search"
            },
            "tool_name": "web_search",
            "request_format": {
                "type": "openai_tool_extension",
                "description": "GLM uses OpenAI tools format with special web_search type",
                "structure": {
                    "type": "web_search",
                    "web_search": {
                        "enable": true,
                        "search_result": true
                    }
                }
            }
        }
    },
